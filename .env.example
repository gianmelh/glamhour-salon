# PostgreSQL connection used by the backend API.
DATABASE_URL=postgresql://localhost/glamhour_dev

# Backend HTTP configuration.
API_PORT=3001
API_HOST=127.0.0.1
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development
APP_URL=http://localhost:5173
VITE_API_URL=http://127.0.0.1:3001/api
VITE_SALON_ID=10000000-0000-0000-0000-000000000001
VITE_GOOGLE_MAPS_API_KEY=
VITE_FACEBOOK_APP_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
VITE_APPLE_CLIENT_ID=
APPLE_CLIENT_ID=

# Set to true when the PostgreSQL provider requires TLS.
DATABASE_SSL=false

# SMTP account used to email password reset verification codes.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
